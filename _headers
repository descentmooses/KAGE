# Cache policy for static hosting (Netlify, Cloudflare Pages, etc.)
# GitHub Pages ignores this file — see index.html meta tags + version.json for GH Pages.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin

/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/KAGE/
  Cache-Control: no-cache, no-store, must-revalidate

/KAGE/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/KAGE/assets/*
  Cache-Control: public, max-age=31536000, immutable

/version.json
  Cache-Control: no-cache, no-store, must-revalidate

/KAGE/version.json
  Cache-Control: no-cache, no-store, must-revalidate
